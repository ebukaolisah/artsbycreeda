# =========================================================
# ArtsByCreeda — environment variables
# Copy these into Vercel project Settings -> Environment Variables.
# Production + Preview + Development.
# =========================================================

# --- Public base URL of the site (used for Paystack callbacks + Telegram links)
NEXT_PUBLIC_BASE_URL=https://artsbycreeda.com

# --- Paystack (https://dashboard.paystack.com/#/settings/developers)
# Use the sk_test_... and pk_test_... keys for staging, sk_live_... / pk_live_... for production.
PAYSTACK_SECRET_KEY=YOUR_PAYSTACK_SECRET_KEY_HERE
PAYSTACK_PUBLIC_KEY=YOUR_PAYSTACK_PUBLIC_KEY_HERE
# Webhook URL to register in Paystack dashboard:
#   https://artsbycreeda.com/api/paystack/webhook

# --- Telegram bot (talk to @BotFather, then /newbot)
# Format: <numeric_id>:<35-char-alphanumeric-secret>  (provided by BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
# Run this once after creating the bot & sending it a /start message:
#   curl https://api.telegram.org/bot<your-token>/getUpdates
# Then copy chat.id here.
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# --- Admin dashboard
# Long random string for JWT signing. Generate one with:
#   openssl rand -base64 48
ADMIN_JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
# The password you'll use at /admin/login
ADMIN_PASSWORD=change-this-to-something-strong

# --- Auto-injected by Vercel (do NOT set manually):
# POSTGRES_URL, POSTGRES_PRISMA_URL, POSTGRES_URL_NON_POOLING,
# POSTGRES_USER, POSTGRES_HOST, POSTGRES_PASSWORD, POSTGRES_DATABASE,
# BLOB_READ_WRITE_TOKEN
